{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "audio-manager",
  "version": "0.1.0",
  "identifier": "com.sarmad.audiomanager",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build && pnpm build:phone",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "audio-manager",
        "width": 1280,
        "height": 820,
        "minWidth": 760,
        "minHeight": 560,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
