{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AudioManager",
  "version": "0.1.0",
  "identifier": "com.sarmad.audiomanager",
  "mainBinaryName": "AudioManager",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build && pnpm build:phone",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AudioManager",
        "width": 1280,
        "height": 820,
        "minWidth": 760,
        "minHeight": 560,
        "resizable": true,
        "center": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "Sarmad Domit",
    "copyright": "Copyright © 2026 Sarmad Domit",
    "licenseFile": "../LICENSE",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
